  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@biomejs/js-api": "~0.6.2",
    "@biomejs/wasm-nodejs": "1.8.3"
  }
}
